####### Compile

main.o: main.cpp mainwindow.h \
		database/databasemanager.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o main.cpp

mainwindow.o: mainwindow.cpp mainwindow.h \
		pages/dashboardpage.h \
		pages/clientspage.h \
		pages/invoicespage.h \
		pages/reportspage.h \
		pages/settingspage.h \
		auth/loginoverlay.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o mainwindow.o mainwindow.cpp

authservice.o: auth/authservice.cpp auth/authservice.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o authservice.o auth/authservice.cpp

loginoverlay.o: auth/loginoverlay.cpp auth/loginoverlay.h \
		auth/authservice.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o loginoverlay.o auth/loginoverlay.cpp

databasemanager.o: database/databasemanager.cpp database/databasemanager.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o databasemanager.o database/databasemanager.cpp

dashboardpage.o: pages/dashboardpage.cpp pages/dashboardpage.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o dashboardpage.o pages/dashboardpage.cpp

clientspage.o: pages/clientspage.cpp pages/clientspage.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o clientspage.o pages/clientspage.cpp

invoicespage.o: pages/invoicespage.cpp pages/invoicespage.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o invoicespage.o pages/invoicespage.cpp

reportspage.o: pages/reportspage.cpp pages/reportspage.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o reportspage.o pages/reportspage.cpp

settingspage.o: pages/settingspage.cpp pages/settingspage.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o settingspage.o pages/settingspage.cpp

moc_mainwindow.o: moc_mainwindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_mainwindow.o moc_mainwindow.cpp

moc_loginoverlay.o: moc_loginoverlay.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_loginoverlay.o moc_loginoverlay.cpp

moc_dashboardpage.o: moc_dashboardpage.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_dashboardpage.o moc_dashboardpage.cpp

moc_clientspage.o: moc_clientspage.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_clientspage.o moc_clientspage.cpp


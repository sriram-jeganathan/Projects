	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents /usr/lib64/qt6/mkspecs/features/data/dummy.cpp $(DISTDIR)/
	$(COPY_FILE) --parents mainwindow.h auth/authservice.h auth/loginoverlay.h database/databasemanager.h pages/dashboardpage.h pages/clientspage.h pages/invoicespage.h pages/reportspage.h pages/settingspage.h $(DISTDIR)/
